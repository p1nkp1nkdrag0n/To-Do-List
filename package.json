{
  "name": "team-project-manager-v1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node --watch server/index.js",
    "client:dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.js",
    "seed:demo": "node scripts/seed-demo.js",
    "invite:create": "node scripts/create-invites.js",
    "test": "node --test server/*.test.js src/*.test.js",
    "test:startup": "node --test server/startup.test.js",
    "check": "npm run build && npm test && npm audit --omit=dev"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "concurrently": "^10.0.3",
    "express": "^4.21.2",
    "lucide-react": "^1.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.12.0",
    "vite": "^8.0.16",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  }
}
